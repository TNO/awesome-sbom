{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update latest_version in tool pages from GitHub Releases",
      "fileMatch": ["^content/tools/(?!_).+\\.md$"],
      "matchStrings": [
        "link: \"https://github\\.com/(?<depName>[^/\"]+/[^/\"]+?)(?:/[^\"]*)?\"[\\s\\S]*?latest_version: \"(?<currentValue>v?[0-9][^\" \"]*)\""
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerce"
    }
  ]
}
